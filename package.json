{
  "name": "optaris-desktop",
  "productName": "Optaris",
  "version": "1.0.0",
  "private": true,
  "main": "./out/main/index.js",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "build:gateway": "bash scripts/build-gateway.sh",
    "build:gateway:mac:arm64": "bash scripts/build-gateway.sh darwin/arm64",
    "build:gateway:mac:x64": "bash scripts/build-gateway.sh darwin/amd64",
    "build:gateway:win": "bash scripts/build-gateway.sh windows/amd64",
    "build:gateway:linux": "bash scripts/build-gateway.sh linux/amd64",
    "predev": "npm run build:gateway",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build:gateway && npm run build && electron-builder --dir",
    "build:win": "npm run build:gateway:win && npm run build && electron-builder --win",
    "build:mac:arm64": "npm run build:gateway:mac:arm64 && electron-vite build && electron-builder --mac --arm64",
    "build:mac:x64": "npm run build:gateway:mac:x64 && electron-vite build && electron-builder --mac --x64",
    "build:mac": "npm run build:mac:arm64 && npm run build:mac:x64",
    "build:linux": "npm run build:gateway:linux && electron-vite build && electron-builder --linux",
    "deploy:mac": "bash scripts/deploy-mac.sh"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@tailwindcss/vite": "^4.3.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.3.9",
    "lucide-react": "^1.24.0",
    "next-themes": "^0.4.6",
    "shadcn": "^4.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
